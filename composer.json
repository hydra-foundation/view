{
    "name": "hydrakit/view",
    "description": "Native PHP templating for the Hydra PHP framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hydra\\View\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hydra\\View\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../core", "options": { "symlink": true } },
        { "type": "path", "url": "../http", "options": { "symlink": true } },
        { "type": "path", "url": "../session", "options": { "symlink": true } },
        { "type": "path", "url": "../csrf", "options": { "symlink": true } }
    ],
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "hydrakit/csrf": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "hydrakit/session": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
